# Mapbox — get a public token from https://account.mapbox.com/access-tokens/
# IMPORTANT: restrict this token to your deployed domain(s) in the Mapbox dashboard
VITE_APP_MAPBOX_TOKEN=pk.your-mapbox-token-here

# Firebase web config — from Firebase Console → Project Settings → General
# These values are safe to expose (they identify your project, not authenticate users),
# but make sure you have Firebase Security Rules and authorized-domain restrictions set up.
VITE_FIREBASE_API_KEY=AIzaSy-your-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxxxxxxxx
